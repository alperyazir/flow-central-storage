# Flow Central Storage — Production Environment Variables
# Copy to apps/api/.env and fill in all values

# === REQUIRED ===

# Database
POSTGRES_DB=flow_central
POSTGRES_USER=postgres
POSTGRES_PASSWORD=  # Strong password
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@postgres:5432/flow_central

# MinIO Object Storage
MINIO_ROOT_USER=  # Change from default
MINIO_ROOT_PASSWORD=  # Strong password, min 8 chars
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=  # Same as MINIO_ROOT_USER
MINIO_SECRET_KEY=  # Same as MINIO_ROOT_PASSWORD
MINIO_SECURE=false  # true if using HTTPS

# Security
SECRET_KEY=  # Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=  # Strong password

# Redis
REDIS_URL=redis://redis:6379/0

# === OPTIONAL ===

# API Keys (managed via admin panel)
# No env vars needed — keys are stored in database

# CORS
CORS_ORIGINS=https://dashboard.yourdomain.com,https://admin.yourdomain.com

# Webhook
WEBHOOK_SECRET=  # Min 16 characters, shared with LMS

# Environment
ENVIRONMENT=production
