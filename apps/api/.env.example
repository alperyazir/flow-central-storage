# Flow Central Storage API environment variables
FCS_DATABASE_SCHEME=postgresql+psycopg
FCS_DATABASE_HOST=pgbouncer
FCS_DATABASE_PORT=6432
FCS_DATABASE_USER=flow_admin
FCS_DATABASE_PASSWORD=flow_password
FCS_DATABASE_NAME=flow_central

# SeaweedFS S3-compatible storage (replaces MinIO)
FCS_MINIO_ENDPOINT=seaweedfs-s3:8333
FCS_MINIO_EXTERNAL_URL=http://localhost:8333
FCS_MINIO_ACCESS_KEY=admin
FCS_MINIO_SECRET_KEY=admin
FCS_MINIO_SECURE=false

FCS_JWT_SECRET_KEY=dev_secret_key
FCS_JWT_ALGORITHM=HS256
FCS_CORS_ALLOWED_ORIGINS=http://localhost:5173
